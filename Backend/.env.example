# KavachNet Configuration Template
# Copy this to .env and fill in the values

# ── Security Keys ──────────────────────────────────
# Generate strong random strings for production
SECRET_KEY=yoursecretkeyhere
JWT_SECRET_KEY=yourjwtsecretkeyhere

# ── Super Admin ────────────────────────────────────
SUPERADMIN_USERNAME=kavachnet_root
SUPERADMIN_PASSWORD=strongpasswordhere

# ── Database ───────────────────────────────────────
DB_NAME=kavachnet.db

# ── Email / SMTP (Required for MFA) ────────────────
EMAIL_PROVIDER=smtp
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_DRY_RUN=True

# ── CORS & Deployment ─────────────────────────────
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Machine Learning & AI ──────────────────────────
GOOGLE_API_KEY=yourgoogleapikeyhere

# ── Redis (Optional, falls back to in-memory) ─────
# REDIS_URL=redis://localhost:6379/0

# ── AWS Deployment (Optional) ─────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
